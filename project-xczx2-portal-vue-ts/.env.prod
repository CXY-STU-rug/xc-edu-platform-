# 前台管理页面-端口
VUE_APP_CLIENT_MANAGE_PORT=7291
# 首页、列表、学习
VUE_APP_CLIENT_PORTAL_URL=http://www.51xuecheng.cn
# 后台服务网关（相对路径，经容器 nginx 反代到宿主机网关 63010）
VUE_APP_SERVER_API_URL=/api
# 权限认证
VUE_APP_SERVER_AUTHORIZATION=
# Cookie域
VUE_APP_SERVER_DOMAIN=51xuecheng.cn
# 静态页/媒资入口（nginx 反代 MinIO）
VUE_APP_SERVER_QINIU_URL=http://file.51xuecheng.cn
